# ── LLM Models ────────────────────────────────────────────────────────────────
# Each component has its own model so you can tune quality vs cost independently.
# Supported formats:
#   OpenAI direct:    gpt-4o-mini, gpt-4o
#   OpenRouter:       openrouter/openai/gpt-4o, openrouter/anthropic/claude-3.5-haiku
#
# Key routing: "openrouter/..." models use OPENROUTER_API_KEY, all others use LLM_API_KEY.

# Planner: decides search vs clarify vs respond — use your smartest model here.
PLANNER_MODEL=gpt-5.4-mini

# QueryRewriter: extracts semantic query + filters as structured JSON — fast model is fine.
QUERY_REWRITER_MODEL=gpt-4o-mini

# Evaluator: binary check on whether retrieved results satisfy the intent — fast model is fine.
EVALUATOR_MODEL=gpt-4o-mini

# Synthesis: generates the final user-facing response — balance quality and cost.
SYNTHESIS_MODEL=gpt-4o-mini

# ── API Keys ──────────────────────────────────────────────────────────────────
# OpenAI key — used for LLM calls (default provider) and OpenAI embeddings.
OPENAI_API_KEY=sk-...

# OpenRouter key — used when any model above is set to "openrouter/<provider>/<model>".
# OpenRouter handles LLM calls only — it has no embeddings endpoint.
OPENROUTER_API_KEY=sk-or-...

# ── Embeddings ────────────────────────────────────────────────────────────────
# backend: "local" (sentence-transformers, runs offline, no key needed)
#          "openai" (OpenAI /v1/embeddings — requires OPENAI_API_KEY above)
EMBEDDING_BACKEND=local

# Model name for the chosen backend:
#   local  → all-MiniLM-L6-v2 (384-dim, fast)
#   openai → text-embedding-3-small (1536-dim, better quality, costs ~$0.02/1M tokens)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Vector Store ──────────────────────────────────────────────────────────────
# Path where ChromaDB persists its data.
CHROMA_PERSIST_DIR=chroma_db

# Collection name inside ChromaDB.
CHROMA_COLLECTION=products

# ── HuggingFace ───────────────────────────────────────────────────────────────
# Token for HF Hub access (datasets, model downloads, etc.)
HF_TOKEN=hf_...

# HuggingFace dataset repo to push structured JSON datasets to.
# Format: username/repo-name  (e.g. your-username/chatshop-headphones)
HF_DATASET_REPO=

# ── Data ──────────────────────────────────────────────────────────────────────
# Directory containing raw CSV files (gitignored).
DATA_RAW_DIR=data/raw

# ── RAG ───────────────────────────────────────────────────────────────────────
# Number of products to retrieve per query.
TOP_K_RESULTS=5

# ── Langfuse Observability ──────────────────────────────────────────────────
# Optional — leave blank to disable tracing entirely.
# Sign up at https://cloud.langfuse.com, create a project, copy keys from Settings → API Keys.
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com
