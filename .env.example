# ── LLM ──────────────────────────────────────────────────────────────────────
# LiteLLM model string. Examples:
#   OpenAI:  gpt-4o-mini  (default)
#   Ollama:  ollama/llama3.2
LITELLM_MODEL=gpt-4o-mini

# API key for the chosen LLM provider.
# For Ollama (local), leave blank or omit.
LITELLM_API_KEY=sk-...

# ── Embeddings ────────────────────────────────────────────────────────────────
# Sentence-transformers model name (runs locally, no API key needed).
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Vector Store ──────────────────────────────────────────────────────────────
# Path where ChromaDB persists its data.
CHROMA_PERSIST_DIR=chroma_db

# Collection name inside ChromaDB.
CHROMA_COLLECTION=products

# ── HuggingFace ───────────────────────────────────────────────────────────────
# Token for HF Hub access (datasets, model downloads, etc.)
HF_TOKEN=hf_...

# ── Data ──────────────────────────────────────────────────────────────────────
# Directory containing raw CSV files (gitignored).
DATA_RAW_DIR=data/raw

# ── RAG ───────────────────────────────────────────────────────────────────────
# Number of products to retrieve per query.
TOP_K_RESULTS=5
