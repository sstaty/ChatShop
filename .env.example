# ── LLM ──────────────────────────────────────────────────────────────────────
# LiteLLM model string. Examples:
#   OpenAI direct:   gpt-4o-mini  (default)
#   Anthropic direct: claude-3-5-haiku-20241022
#   Ollama (local):  ollama/llama3.2
#   OpenRouter:      openrouter/openai/gpt-4o-mini
#                    openrouter/anthropic/claude-3.5-haiku
#                    openrouter/google/gemini-flash-1.5
LITELLM_MODEL=gpt-4o-mini

# API key for direct LLM provider (OpenAI, Anthropic, etc.).
# Leave blank if using OpenRouter instead.
LITELLM_API_KEY=sk-...

# ── OpenRouter ────────────────────────────────────────────────────────────────
# Single key to access any frontier model via openrouter.ai.
# Set LITELLM_MODEL to "openrouter/<provider>/<model>" to activate.
# NOTE: OpenRouter handles LLM calls only — it has no embeddings endpoint.
OPENROUTER_API_KEY=sk-or-...

# ── Embeddings ────────────────────────────────────────────────────────────────
# backend: "local" (sentence-transformers, runs offline, no key needed)
#          "openai" (OpenAI /v1/embeddings — requires OPENAI_API_KEY below)
EMBEDDING_BACKEND=local

# Model name for the chosen backend:
#   local  → all-MiniLM-L6-v2 (384-dim, fast)
#   openai → text-embedding-3-small (1536-dim, better quality, costs ~$0.02/1M tokens)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# OpenAI API key — used only when EMBEDDING_BACKEND=openai.
# (Also works as LITELLM_API_KEY if your LLM provider is OpenAI.)
OPENAI_API_KEY=sk-...

# ── Vector Store ──────────────────────────────────────────────────────────────
# Path where ChromaDB persists its data.
CHROMA_PERSIST_DIR=chroma_db

# Collection name inside ChromaDB.
CHROMA_COLLECTION=products

# ── HuggingFace ───────────────────────────────────────────────────────────────
# Token for HF Hub access (datasets, model downloads, etc.)
HF_TOKEN=hf_...

# HuggingFace dataset repo to push structured JSON datasets to.
# Format: username/repo-name  (e.g. your-username/chatshop-headphones)
HF_DATASET_REPO=

# ── Data ──────────────────────────────────────────────────────────────────────
# Directory containing raw CSV files (gitignored).
DATA_RAW_DIR=data/raw

# ── RAG ───────────────────────────────────────────────────────────────────────
# Number of products to retrieve per query.
TOP_K_RESULTS=5
